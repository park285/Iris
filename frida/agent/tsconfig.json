{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "lib": ["ES2022"],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["frida-gum", "node"]
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "generated",
    "node_modules"
  ]
}
