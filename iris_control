#!/usr/bin/env bash

set -euo pipefail

IRIS_PROCESS_NAME="party.qwer.iris.Main"
IRIS_PROCESS_KEYWORD="app_process"
IRIS_APK_URL="https://github.com/park285/Iris/releases/latest/download/Iris.apk"
IRIS_APK_PATH="/data/local/tmp/Iris.apk"
IRIS_APK_LOCAL_FILE="Iris.apk"
IRIS_MD5_URL="${IRIS_APK_URL}.MD5"
IRIS_CONFIG_PATH="${IRIS_CONFIG_PATH:-/data/local/tmp/config.json}"
IRIS_WEBHOOK_TRANSPORT="${IRIS_WEBHOOK_TRANSPORT:-}"
IRIS_WEBHOOK_TOKEN="${IRIS_WEBHOOK_TOKEN:-}"
IRIS_BOT_TOKEN="${IRIS_BOT_TOKEN:-}"
IRIS_LOG_LEVEL="${IRIS_LOG_LEVEL:-}"

ADB_CMD=""

check_linux_host() {
  if [[ "$(uname -s)" != "Linux" ]]; then
    echo "iris_control is supported on Linux hosts only."
    return 1
  fi
}

check_adb_installed() {
  if ! command -v adb >/dev/null 2>&1; then
    echo "adb is not installed. Please install adb and add it to your PATH."
    echo "For Debian/Ubuntu, try: sudo apt-get install adb"
    return 1
  fi
}

select_adb_device() {
  if [[ -n "$ADB_CMD" ]]; then
    return 0
  fi

  echo "Searching for connected devices..."
  mapfile -t devices < <(adb devices | awk '$2 == "device" {print $1}')

  case "${#devices[@]}" in
    0)
      echo "Error: No adb devices found in 'device' state."
      echo "Connect a device or run: adb connect <ip>:<port>"
      return 1
      ;;
    1)
      ADB_CMD="adb -s ${devices[0]}"
      echo "Using device: ${devices[0]}"
      ;;
    *)
      echo "Multiple devices found. Choose one:"
      local i=1
      for device in "${devices[@]}"; do
        echo "  $i) $device"
        i=$((i + 1))
      done

      local choice
      read -r -p "Enter number (1-${#devices[@]}): " choice
      if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#devices[@]} )); then
        echo "Error: Invalid selection."
        return 1
      fi

      local device_id="${devices[$((choice - 1))]}"
      ADB_CMD="adb -s $device_id"
      echo "Using device: $device_id"
      ;;
  esac
}

get_iris_pid() {
  "$ADB_CMD" shell ps -f |
    grep "$IRIS_PROCESS_NAME" |
    grep "$IRIS_PROCESS_KEYWORD" |
    grep -v 'grep' |
    grep -v 'sh -c' |
    awk '{print $2}'
}

iris_status() {
  local pid
  pid="$(get_iris_pid || true)"
  if [[ -n "$pid" ]]; then
    echo "Iris is running. PID: $pid"
  else
    echo "Iris is not running."
  fi
}

build_remote_runtime_command() {
  local redirect_suffix="${1:-}"
  cat <<EOF
IRIS_CONFIG_PATH="$IRIS_CONFIG_PATH" IRIS_WEBHOOK_TRANSPORT="$IRIS_WEBHOOK_TRANSPORT" IRIS_WEBHOOK_TOKEN="$IRIS_WEBHOOK_TOKEN" IRIS_BOT_TOKEN="$IRIS_BOT_TOKEN" IRIS_LOG_LEVEL="$IRIS_LOG_LEVEL" CLASSPATH="$IRIS_APK_PATH" app_process / party.qwer.iris.Main$redirect_suffix
EOF
}

iris_start() {
  local pid
  pid="$(get_iris_pid || true)"
  if [[ -n "$pid" ]]; then
    echo "Iris is already running."
    return 0
  fi

  echo "Starting Iris service in the background..."
  local remote_command
  remote_command="$(build_remote_runtime_command ' > /dev/null 2>&1 &')"
  "$ADB_CMD" shell "su root sh -c '$remote_command'"
  sleep 2

  local new_pid
  new_pid="$(get_iris_pid || true)"
  if [[ -n "$new_pid" ]]; then
    echo "Iris service started. PID: $new_pid"
  else
    echo "Failed to start Iris service."
    return 1
  fi
}

iris_start_foreground() {
  local pid
  pid="$(get_iris_pid || true)"
  if [[ -n "$pid" ]]; then
    echo "Iris is already running (PID: $pid). Stop it first with '$0 stop'."
    return 1
  fi

  echo "Starting Iris in foreground..."
  echo "Press Ctrl+C to stop the foreground adb session."
  local remote_command
  remote_command="$(build_remote_runtime_command)"
  "$ADB_CMD" shell "su root sh -c '$remote_command'"
}

iris_stop() {
  local pid
  pid="$(get_iris_pid || true)"
  if [[ -z "$pid" ]]; then
    echo "Iris is not running."
    return 0
  fi

  echo "Stopping Iris service..."
  "$ADB_CMD" shell "su root sh -c 'kill -s SIGTERM $pid'"
  for _ in 1 2 3 4 5; do
    sleep 1
    if [[ -z "$(get_iris_pid || true)" ]]; then
      echo "Iris service stopped gracefully."
      return 0
    fi
  done

  echo "SIGTERM timed out; forcing SIGKILL..."
  "$ADB_CMD" shell "su root sh -c 'kill -s SIGKILL $pid'"
  sleep 1
  if [[ -z "$(get_iris_pid || true)" ]]; then
    echo "Iris service stopped after SIGKILL fallback."
  else
    echo "Failed to stop Iris service (PID: $pid may still be running)."
    return 1
  fi
}

download_file() {
  local url="$1"
  local output="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "$output" "$url"
  elif command -v wget >/dev/null 2>&1; then
    wget -O "$output" "$url"
  else
    echo "Error: curl or wget is required."
    return 1
  fi
}

verify_md5_if_available() {
  local apk_file="$1"
  local md5_file="$2"

  if [[ ! -f "$md5_file" ]]; then
    echo "Warning: MD5 file missing. Skipping checksum verification."
    return 0
  fi

  if ! command -v md5sum >/dev/null 2>&1; then
    echo "Warning: md5sum is not installed. Skipping checksum verification."
    return 0
  fi

  local downloaded_md5
  downloaded_md5="$(awk '{print $1}' "$md5_file")"
  local calculated_md5
  calculated_md5="$(md5sum "$apk_file" | awk '{print $1}')"

  if [[ "${downloaded_md5,,}" != "${calculated_md5,,}" ]]; then
    echo "MD5 checksum mismatch! Downloaded file is corrupted."
    return 1
  fi

  echo "MD5 checksum verification passed."
}

iris_install() {
  trap cleanup_install_artifacts RETURN

  echo "Downloading Iris.apk..."
  download_file "$IRIS_APK_URL" "$IRIS_APK_LOCAL_FILE"

  echo "Downloading MD5 checksum..."
  if ! download_file "$IRIS_MD5_URL" "$IRIS_APK_LOCAL_FILE.MD5"; then
    echo "Warning: Failed to download MD5 checksum. Continuing without checksum verification."
  fi

  verify_md5_if_available "$IRIS_APK_LOCAL_FILE" "$IRIS_APK_LOCAL_FILE.MD5"

  echo "Pushing Iris.apk to device..."
  "$ADB_CMD" push "$IRIS_APK_LOCAL_FILE" "$IRIS_APK_PATH"

  echo "Verifying installation..."
  if "$ADB_CMD" shell "ls $IRIS_APK_PATH" >/dev/null 2>&1; then
    echo "Installation completed successfully."
  else
    echo "Installation verification failed. File might not be at $IRIS_APK_PATH."
    return 1
  fi
}

cleanup_install_artifacts() {
  rm -f "$IRIS_APK_LOCAL_FILE" "$IRIS_APK_LOCAL_FILE.MD5"
}

main() {
  check_linux_host || exit 1

  case "${1:-}" in
    status|start|stop|install)
      check_adb_installed || exit 1
      select_adb_device || exit 1
      ;;
  esac

  case "${1:-}" in
    status)
      iris_status
      ;;
    start)
      if [[ "${2:-}" == "-v" || "${2:-}" == "--verbose" ]]; then
        iris_start_foreground
      else
        iris_start
      fi
      ;;
    stop)
      iris_stop
      ;;
    install)
      iris_install
      ;;
    *)
      echo "Usage: $0 {status|start [-v|--verbose]|stop|install}"
      exit 1
      ;;
  esac
}

main "$@"
